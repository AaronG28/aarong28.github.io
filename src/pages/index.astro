---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');

// Definimos las categorías como un array de literales para TypeScript
const categories = ['economia', 'politica', 'tecnologia', 'historia'] as const;
type Categoria = typeof categories[number]; 

const categoryNames: Record<Categoria, string> = {
  economia: 'Economía',
  politica: 'Política',
  tecnologia: 'Tecnología',
  historia: 'Historia'
};
---

<BaseLayout>
  <section class="home-banner">
    <h1>Bienvenido a Analítica360</h1>
    <p>Análisis en Economía, Política, Tecnología e Historia</p>
  </section>

  {categories.map((cat) => {
    const catArticles = articulos
      .filter(a => a.data.category === cat)
      .slice(0, 3);
    return (
      <section class="category-section">
        <h2>{categoryNames[cat]}</h2>
        <div class="articles-grid">
          {catArticles.map(a => {
            // Extraemos el slug del id (ej: "politica/epistocracia-vs-democracia.md" → "epistocracia-vs-democracia")
            const slugFromId = a.id.replace(/\.md$/, '').split('/').pop();
            return (
              <ArticleCard
                title={a.data.title}
                description={a.data.description}
                image={a.data.image}
                url={`/${a.data.category}/${slugFromId}`}
                date={a.data.date}
              />
            );
          })}
        </div>
      </section>
    );
  })}
</BaseLayout>